# ---------------------------------------------------------------------------
# Python / uv
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ---------------------------------------------------------------------------
# befkb engine — regenerable state (rebuild any time with `befkb ingest`)
# ---------------------------------------------------------------------------
befkb/data/
*.qmd-index

# ---------------------------------------------------------------------------
# raw/ sources — keep the folder + SOURCES.md, NOT the (copyrighted) PDF binaries
# ---------------------------------------------------------------------------
raw/*.pdf
raw/*.PDF

# ---------------------------------------------------------------------------
# Obsidian (keep the vault content; drop local UI state)
# ---------------------------------------------------------------------------
.obsidian/workspace*
.obsidian/cache
.trash/

# ---------------------------------------------------------------------------
# Claude Code local config / OS / editor cruft
# ---------------------------------------------------------------------------
.claude/
.DS_Store
*.swp
