# Hot Science Research Agents local configuration

# Contact emails are used for polite scholarly API access where supported.
DEEPGREEN_CONTACT_EMAIL=<your-team-contact-email>
OPENALEX_MAILTO=<your-team-contact-email>
CROSSREF_MAILTO=<your-team-contact-email>
UNPAYWALL_EMAIL=<your-team-contact-email>

# Optional source/API keys. Leave blank unless available.
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
CORE_API_KEY=
SPRINGER_NATURE_API_KEY=
ELSEVIER_API_KEY=
SCOPUS_API_KEY=
NOAA_CDO_TOKEN=
NYT_API_KEY=
GUARDIAN_API_KEY=

# Optional enrichments.
HOT_SCIENCE_ENABLE_UNPAYWALL=0
HOT_SCIENCE_DOWNLOAD_PDFS=0
HOT_SCIENCE_ENABLE_BEDROCK_EMBEDDINGS=0

# Local run state and generated artifacts.
HOT_SCIENCE_DATA_DIR=.deepgreen/hot_science
HOT_SCIENCE_REPORT_RETENTION_DAYS=30

# Local/Fly pilot UI auth. Set real values locally or as Fly secrets.
DEEPGREEN_UI_USERS_JSON={"user1":"<password1>","user2":"<password2>","user3":"<password3>","user4":"<password4>","user5":"<password5>","user6":"<password6>","user7":"<password7>"}
DEEPGREEN_UI_ADMIN_USERS=user1
DEEPGREEN_UI_SESSION_SECRET=<replace-with-long-random-secret>
DEEPGREEN_UI_SESSION_TTL_SECONDS=43200

# Only required if HOT_SCIENCE_ENABLE_BEDROCK_EMBEDDINGS=1.
AWS_REGION=us-east-1
AWS_PROFILE=<optional-aws-profile>
MODEL_EMBED=amazon.titan-embed-text-v2:0
MODEL_STRONG=<optional-bedrock-model-id>
MODEL_FAST=<optional-bedrock-model-id>
MODEL_LITE=<optional-bedrock-model-id>
