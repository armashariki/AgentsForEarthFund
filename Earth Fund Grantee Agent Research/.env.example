# Grant Proposal Analyzer - Environment Configuration
# Copy this file to .env and fill in your values
#
# SECURITY WARNING: Never commit .env files with real API keys to version control

# =============================================================================
# LLM API KEYS (at least one required)
# =============================================================================

# Anthropic Claude API Key (recommended for best results)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Google AI (Gemini) API Key
GOOGLE_API_KEY=your-google-api-key-here

# xAI (Grok) API Key
XAI_API_KEY=your-xai-api-key-here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Port to expose the application (default: 8501)
APP_PORT=8501

# =============================================================================
# PRODUCTION SETTINGS (for docker-compose.prod.yml)
# =============================================================================

# Secure cookie secret for session management (generate a random string)
# Example: openssl rand -hex 32
COOKIE_SECRET=your-secure-random-secret-here

# =============================================================================
# OPTIONAL: LOGGING & MONITORING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================

# If using external database for session storage (future enhancement)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# If using Redis for caching (future enhancement)
# REDIS_URL=redis://host:6379/0
