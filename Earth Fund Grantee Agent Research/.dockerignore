# Grant Proposal Analyzer - Docker Ignore File
# Files and directories to exclude from Docker build context

# Virtual environments
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Environment files (NEVER include in image)
.env
.env.local
.env.*.local

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore

# Docker files (not needed in image)
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
docs/

# Test files
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Output directory (mounted as volume)
output/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Nginx config (mounted separately)
nginx/

# SSL certificates (mounted separately)
ssl/
*.pem
*.key
*.crt
